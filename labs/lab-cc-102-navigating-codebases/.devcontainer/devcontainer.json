{
    "name": "Lab CC-102: Navigating Codebases",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
    "postCreateCommand": "npm install",
    "customizations": {
        "vscode": {
            "extensions": ["anthropics.claude-code"]
